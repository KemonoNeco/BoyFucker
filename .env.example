# Copy to .env and fill in. .env is gitignored — never commit the real token.
# Get a token: https://discord.com/developers/applications -> your app -> Bot -> Reset Token
DISCORD_TOKEN=

# PostgreSQL connection (required). The bundled docker-compose.yml serves this exact URL:
#   docker compose up -d
DATABASE_URL=postgres://boyfucker:boyfucker@localhost:5432/boyfucker

# Optional: register slash commands instantly in one guild during dev (else global, ~1h).
# TEST_GUILD_ID=

# Optional: log level (default "info"). e.g. RUST_LOG=boyfucker=debug,serenity=warn
# RUST_LOG=info
